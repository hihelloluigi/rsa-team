# ==============================================================================
# RSA TEAM — .gitignore
# Next.js · Vercel · TypeScript
# ==============================================================================

# ==============================================================================
# Secrets & environment — never commit
# ==============================================================================

.env*
!.env.example

# Certificate and key files
*.pem

# ==============================================================================
# Node / npm
# ==============================================================================

node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Debug logs from package managers
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ==============================================================================
# Next.js
# ==============================================================================

.next/
out/

# ==============================================================================
# Build output
# ==============================================================================

build/
*.tsbuildinfo
next-env.d.ts

# ==============================================================================
# Testing & coverage
# ==============================================================================

coverage/

# ==============================================================================
# Vercel
# ==============================================================================

.vercel/

# ==============================================================================
# IDE & editors
# ==============================================================================

.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.recommended.json

# ==============================================================================
# OS files
# ==============================================================================

.DS_Store
Thumbs.db

# ==============================================================================
# AI tools — local brainstorming artifacts, never shared
# ==============================================================================

.claude/
.codex/
.superpowers/
docs/superpowers/
